{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": false,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "js/MainPage/**/*.ts", "js/StandardLibraryIntellisense.ts", "build.ts", "serve.ts"]
}
